{
  "uid": "marketplace-runtime-dotnet",
  "title": "Marketplace .NET Runtime",
  "tags": ["marketplace", "runtime"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "GC heap size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "process_runtime_dotnet_gc_heap_size_bytes",
          "legendFormat": "heap"
        }
      ]
    },
    {
      "id": 2,
      "title": "GC collections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(process_runtime_dotnet_gc_collections_count_total[5m])) by (generation)",
          "legendFormat": "gen {{generation}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Exceptions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(process_runtime_dotnet_exceptions_count_total[5m]))",
          "legendFormat": "exceptions/s"
        }
      ]
    }
  ]
}
