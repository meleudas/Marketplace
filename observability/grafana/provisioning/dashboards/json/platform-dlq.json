{
  "uid": "marketplace-platform-dlq",
  "title": "Marketplace Platform DLQ & Idempotency",
  "tags": ["marketplace", "platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Outbox dead letters",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(increase(outbox_dead_letter_total[1h])) by (category)", "legendFormat": "{{category}}" }]
    },
    {
      "id": 2,
      "title": "Outbox dispatch errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(rate(outbox_dispatch_errors_total[5m])) by (category)", "legendFormat": "{{category}}" }]
    },
    {
      "id": 3,
      "title": "Idempotency conflicts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [{ "expr": "sum(rate(idempotency_conflicts_total[5m])) by (reason)", "legendFormat": "{{reason}}" }]
    },
    {
      "id": 4,
      "title": "Idempotency replays",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [{ "expr": "sum(rate(idempotency_replays_total[5m]))", "legendFormat": "replays" }]
    }
  ]
}
