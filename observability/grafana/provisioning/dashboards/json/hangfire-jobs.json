{
  "uid": "marketplace-hangfire",
  "title": "Marketplace Hangfire Jobs",
  "tags": ["marketplace", "hangfire"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Job executions",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [{ "expr": "sum(rate(hangfire_jobs_total[5m])) by (job)", "legendFormat": "{{job}}" }]
    },
    {
      "id": 2,
      "title": "Job errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [{ "expr": "sum(rate(hangfire_job_errors_total[5m])) by (job)", "legendFormat": "{{job}}" }]
    },
    {
      "id": 3,
      "title": "Job p95 latency (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(hangfire_job_latency_ms_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}}"
        }
      ]
    }
  ]
}
