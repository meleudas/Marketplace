# Google OAuth2
GOOGLEAUTH__CLIENTID=
GOOGLEAUTH__CLIENTSECRET=

# SendGrid (може бути gmail-адреса як verified sender)
SENDGRID__APIKEY=
SENDGRID__FROMEMAIL=
SENDGRID__FROMNAME=Marketplace

# Telegram Bot (2FA)
TELEGRAM__BOTTOKEN=
TELEGRAM__WEBHOOKSECRET=
TELEGRAM__LINKCODETTLMINUTES=10

# LiqPay
LIQPAY__PUBLICKEY=
LIQPAY__PRIVATEKEY=
LIQPAY__APIURL=https://www.liqpay.ua/api
LIQPAY__CHECKOUTBASEURL=https://www.liqpay.ua/api/3/checkout
LIQPAY__CALLBACKBASEURL=https://localhost:7001
LIQPAY__RESULTBASEURL=http://localhost:3000

# Shipping feature flags
SHIPPING__ENABLED=false
SHIPPING__NOVAPOSHTAENABLED=false

# Coupons feature flags
COUPONS__READENABLED=true
COUPONS__CHECKOUTCONSUMEENABLED=true

# Nova Poshta
NOVAPOSHTA__ENABLED=false
NOVAPOSHTA__APIURL=https://api.novaposhta.ua/v2.0/json/
NOVAPOSHTA__APIKEY=
NOVAPOSHTA__FALLBACKFLATRATE=99
NOVAPOSHTA__FALLBACKETAMINDAYS=1
NOVAPOSHTA__FALLBACKETAMAXDAYS=3

# Web Push (VAPID; увімкніть Enabled=true після генерації ключів). Генерація: scripts/generate-vapid-keys.ps1 або npx web-push generate-vapid-keys
WEBPUSH__ENABLED=false
WEBPUSH__SUBJECT=mailto:dev@localhost
WEBPUSH__PUBLICKEY=
WEBPUSH__PRIVATEKEY=

# Застосункові нотифікації (Email/TG через IAppNotificationScheduler; див. appsettings AppNotifications)
APPNOTIFICATIONS__EMAILENABLED=true
APPNOTIFICATIONS__TELEGRAMENABLED=true
APPNOTIFICATIONS__INAPPDEFAULTTTLDAYS=90
APPNOTIFICATIONS__EMAILSUBJECTPREFIX=[Marketplace]
APPNOTIFICATIONS__PRUNEEXPIREDINAPPENABLED=true

# Frontend redirect base URL
FRONTEND__BASEURL=http://localhost:3000
CORS__ALLOWEDORIGINS__0=http://localhost:3000

# JWT secret (>=32 chars)
JWT__SECRETKEY=ChangeThis_DevSecretKey_AtLeast32CharsLong!!

# MinIO / S3 storage
STORAGE__ENABLED=false
STORAGE__ENDPOINT=localhost:9000
STORAGE__ACCESSKEY=minioadmin
STORAGE__SECRETKEY=minioadmin
STORAGE__BUCKET=marketplace-media
STORAGE__USESSL=false
STORAGE__PUBLICBASEURL=http://localhost:9000
STORAGE__PRESIGNEDGETTTLMINUTES=60
STORAGE__MAXUPLOADBYTES=10485760

# OpenTelemetry (увімкніть при docker compose --profile observability)
OTEL_ENABLED=false
GRAFANA_ADMIN_PASSWORD=admin
