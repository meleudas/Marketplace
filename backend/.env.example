# Google OAuth2
GOOGLEAUTH__CLIENTID=
GOOGLEAUTH__CLIENTSECRET=

# SendGrid (може бути gmail-адреса як verified sender)
SENDGRID__APIKEY=
SENDGRID__FROMEMAIL=
SENDGRID__FROMNAME=Marketplace

# Frontend redirect base URL
FRONTEND__BASEURL=http://localhost:3000
CORS__ALLOWEDORIGINS__0=http://localhost:3000

# JWT secret (>=32 chars)
JWT__SECRETKEY=ChangeThis_DevSecretKey_AtLeast32CharsLong!!
