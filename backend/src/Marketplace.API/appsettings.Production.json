{
  "OpenTelemetry": {
    "Enabled": true,
    "EnableLegacyPrometheusEndpoint": false,
    "TraceSamplingRatio": 0.1
  },
  "Reports": {
    "PublicCreateEnabled": false,
    "ModerationEnabled": true,
    "DuplicateCooldownMinutes": 10,
    "RateLimitPerWindow": 5,
    "RateLimitWindowMinutes": 1
  },
  "Chats": {
    "Enabled": false,
    "RealtimeEnabled": false,
    "ModerationEnabled": true,
    "MessagesPerMinute": 10,
    "DuplicateWindowSeconds": 60,
    "MaxMessageLength": 4000,
    "RejectOnProhibitedContent": true,
    "ProhibitedPatterns": []
  },
  "Support": {
    "Enabled": false,
    "HelpdeskSyncEnabled": false,
    "HelpdeskWebhookEnabled": false,
    "CreateRateLimitPerWindow": 5,
    "CreateRateLimitWindowMinutes": 60,
    "SlaHoursP1": 4,
    "SlaHoursP2": 24,
    "WebhookSigningSecret": "",
    "HelpdeskProvider": "logging"
  },
  "BehaviorAnalytics": {
    "BehaviorTrackingEnabled": false,
    "AdminAnalyticsReadEnabled": false,
    "DuplicateWindowSeconds": 30,
    "PayloadMaxBytes": 8192,
    "RateLimitPerMinute": 120,
    "SamplingPercent": 10,
    "RequireConsent": true
  },
  "ClickHouse": {
    "Enabled": false,
    "Url": "http://clickhouse:8123",
    "Database": "marketplace",
    "Username": "default",
    "Password": "",
    "CommandTimeoutSeconds": 30,
    "SignalLookbackDays": 30,
    "SignalHalfLifeDays": 30,
    "FunnelLookbackDays": 30,
    "ViewWeight": 1,
    "SearchWeight": 2,
    "FavoriteWeight": 4,
    "CartWeight": 6,
    "PurchaseWeight": 10
  },
  "RecommendationModel": {
    "Enabled": false,
    "ShadowModeEnabled": true,
    "TopK": 12,
    "CandidatePoolSize": 300,
    "MinUserInteractions": 5,
    "RetrainCron": "0 2 * * *",
    "PromoteCron": "30 2 * * *",
    "CleanupCron": "0 4 * * *",
    "ArtifactPrefix": "ml/recommendations",
    "RegistryPrefix": "ml/recommendations/registry",
    "UsePersonalizedEndpoint": true,
    "FallbackMode": "similar_products"
  },
  "RecommendationTraining": {
    "LookbackDays": 30,
    "TrainTestSplit": 0.2,
    "MatrixFactorizationIterations": 35,
    "MatrixFactorizationLearningRate": 0.08,
    "MatrixFactorizationLambda": 0.03,
    "MatrixFactorizationApproximationRank": 64,
    "MaxTrainingRows": 1000000
  },
  "ReviewsAntiAbuse": {
    "CreatePerUserProductPerDay": 2,
    "CreateWindowMinutes": 1440
  },
  "PaymentWebhookAntiAbuse": {
    "FailedSignaturePerIpPerWindow": 15,
    "FailedSignatureWindowMinutes": 5
  },
  "NotificationDispatchAntiAbuse": {
    "BurstPerTargetPerMinute": 20,
    "BurstWindowSeconds": 60
  }
}
