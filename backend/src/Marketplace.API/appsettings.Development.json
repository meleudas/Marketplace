{
  "OpenTelemetry": {
    "Enabled": true,
    "OtlpEndpoint": "http://localhost:4317",
    "EnableLegacyPrometheusEndpoint": true,
    "TraceSamplingRatio": 1.0
  },
  "Identity": {
    "RequireConfirmedEmail": false
  },
  "Reports": {
    "PublicCreateEnabled": true,
    "ModerationEnabled": true,
    "DuplicateCooldownMinutes": 5,
    "RateLimitPerWindow": 10,
    "RateLimitWindowMinutes": 1
  },
  "Chats": {
    "Enabled": true,
    "RealtimeEnabled": true,
    "ModerationEnabled": true,
    "MessagesPerMinute": 30,
    "DuplicateWindowSeconds": 15,
    "MaxMessageLength": 4000,
    "RejectOnProhibitedContent": true,
    "ProhibitedPatterns": ["(?i)spam"]
  },
  "Support": {
    "Enabled": true,
    "HelpdeskSyncEnabled": true,
    "HelpdeskWebhookEnabled": true,
    "CreateRateLimitPerWindow": 10,
    "CreateRateLimitWindowMinutes": 60,
    "SlaHoursP1": 4,
    "SlaHoursP2": 24,
    "WebhookSigningSecret": "dev-helpdesk-secret",
    "HelpdeskProvider": "logging"
  },
  "BehaviorAnalytics": {
    "BehaviorTrackingEnabled": true,
    "AdminAnalyticsReadEnabled": true,
    "DuplicateWindowSeconds": 10,
    "PayloadMaxBytes": 16384,
    "RateLimitPerMinute": 240,
    "SamplingPercent": 100,
    "RequireConsent": false
  },
  "ClickHouse": {
    "Enabled": true,
    "Url": "http://localhost:8123",
    "Database": "marketplace",
    "Username": "default",
    "Password": "",
    "CommandTimeoutSeconds": 30,
    "SignalLookbackDays": 30,
    "SignalHalfLifeDays": 30,
    "FunnelLookbackDays": 30,
    "ViewWeight": 1,
    "SearchWeight": 2,
    "FavoriteWeight": 4,
    "CartWeight": 6,
    "PurchaseWeight": 10
  },
  "RecommendationModel": {
    "Enabled": true,
    "ShadowModeEnabled": true,
    "TopK": 12,
    "CandidatePoolSize": 300,
    "MinUserInteractions": 3,
    "RetrainCron": "0 */3 * * *",
    "PromoteCron": "15 */3 * * *",
    "CleanupCron": "30 3 * * *",
    "ArtifactPrefix": "ml/recommendations",
    "RegistryPrefix": "ml/recommendations/registry",
    "UsePersonalizedEndpoint": true,
    "FallbackMode": "similar_products"
  },
  "RecommendationTraining": {
    "LookbackDays": 30,
    "TrainTestSplit": 0.2,
    "MatrixFactorizationIterations": 30,
    "MatrixFactorizationLearningRate": 0.1,
    "MatrixFactorizationLambda": 0.025,
    "MatrixFactorizationApproximationRank": 64,
    "MaxTrainingRows": 500000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Console": {
      "IncludeScopes": true
    }
  }
}
